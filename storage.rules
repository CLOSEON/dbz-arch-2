rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Publicly readable uploads for the marketplace
    match /uploads/{allPaths=**} {
      allow read, write: if true;
    }
    
    // Fallback for other paths: requires authentication
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
